generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Signup {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  businessName String?
  website      String?
  notes        String?
  createdAt    DateTime @default(now())
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

model Analysis {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  businessName String
  location     String
  tier         String    @default("fast")
  status       String    @default("pending")
  resultJson   String?
  errorMessage String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  llmJobs      LLMJob[]

  @@index([businessName, location, tier])
  @@index([status])
  @@index([userId])
}

model LLMJob {
  id           String    @id @default(cuid())
  analysisId   String
  analysis     Analysis  @relation(fields: [analysisId], references: [id])
  provider     String
  status       String    @default("pending")
  promptsSent  Int       @default(0)
  rawResponse  String?
  parsedJson   String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([analysisId, provider])
}
