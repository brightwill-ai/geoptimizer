generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signup {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  businessName String?
  website      String?
  notes        String?
  createdAt    DateTime @default(now())
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

model Analysis {
  id                        String            @id @default(cuid())
  userId                    String?
  user                      User?             @relation(fields: [userId], references: [id])
  businessName              String
  location                  String
  category                  String            @default("restaurant")
  businessScope             String            @default("local")
  productDescription        String?
  targetAudience            String?
  tier                      String            @default("fast")
  status                    String            @default("pending")
  resultJson                String?
  errorMessage              String?
  queryCount                Int               @default(0)
  recommendationProbability Float?
  methodology               String?
  shareToken                String?           @unique
  startedAt                 DateTime          @default(now())
  completedAt               DateTime?
  expiresAt                 DateTime?
  createdAt                 DateTime          @default(now())
  actionPlanJson            String?
  actionPlanStatus          String            @default("pending")
  paid                      Boolean           @default(false)
  priceTier                 String            @default("free")
  stripeSessionId           String?
  paidAt                    DateTime?
  email                     String?
  llmJobs                   LLMJob[]
  queryExecutions           QueryExecution[]
  sourceInfluences          SourceInfluence[]
  actionPlanItems           ActionPlanItem[]

  @@index([businessName, location, tier])
  @@index([status])
  @@index([userId])
}

model LLMJob {
  id           String    @id @default(cuid())
  analysisId   String
  analysis     Analysis  @relation(fields: [analysisId], references: [id])
  provider     String
  status       String    @default("pending")
  promptsSent  Int       @default(0)
  rawResponse  String?
  parsedJson   String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([analysisId, provider])
}

model QueryTemplate {
  id         String           @id @default(cuid())
  category   String
  queryType  String
  template   String
  tier       String           @default("free")
  scope      String           @default("all")
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  executions QueryExecution[]

  @@index([category, tier, isActive])
  @@index([scope])
}

model QueryExecution {
  id                String         @id @default(cuid())
  analysisId        String
  analysis          Analysis       @relation(fields: [analysisId], references: [id])
  queryTemplateId   String?
  queryTemplate     QueryTemplate? @relation(fields: [queryTemplateId], references: [id])
  provider          String
  promptSent        String
  rawResponse       String         @default("")
  parsedJson        String?
  modelVersion      String         @default("")
  responseTimeMs    Int?
  businessMentioned Boolean        @default(false)
  mentionType       String?
  rankPosition      Int?
  sentiment         String?
  status            String         @default("pending")
  errorMessage      String?
  createdAt         DateTime       @default(now())

  @@index([analysisId, provider])
  @@index([provider, createdAt])
  @@index([queryTemplateId])
}

model SourceInfluence {
  id            String   @id @default(cuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id])
  sourceType    String
  sourceName    String
  provider      String
  citationCount Int      @default(0)
  influence     String   @default("unknown")
  createdAt     DateTime @default(now())

  @@index([analysisId])
  @@index([sourceType, provider])
}

model ActionPlanItem {
  id            String    @id @default(cuid())
  analysisId    String
  analysis      Analysis  @relation(fields: [analysisId], references: [id])
  categoryKey   String
  categoryLabel String
  itemIndex     Int
  priority      String
  title         String
  description   String
  reasoning     String
  effort        String
  dataPoints    String?
  completed     Boolean   @default(false)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([analysisId, categoryKey])
  @@index([analysisId, completed])
}

// ─── Outreach System ─────────────────────────────────────────────────────────

model EmailAccount {
  id              String   @id @default(cuid())
  label           String
  smtpHost        String   @default("smtp.zoho.com")
  smtpPort        Int      @default(465)
  smtpSecure      Boolean  @default(true)
  smtpUser        String
  smtpPass        String
  fromName        String   @default("William")
  fromEmail       String   @unique
  replyTo         String?

  // Account type: "outreach" (used for cold email + optional warmup) or "warmup_only" (only warmup pool)
  accountType     String   @default("outreach")

  // Cold email warmup (rate limiter ramp)
  warmupEnabled   Boolean  @default(true)
  warmupStartDate DateTime @default(now())
  warmupDay       Int      @default(0)
  warmupPhase     String   @default("phase_1")
  dailyLimit      Int      @default(5)
  sentToday       Int      @default(0)
  sentTodayDate   String   @default("")

  // IMAP credentials (for warmup pool receiving)
  imapHost        String?
  imapPort        Int?     @default(993)
  imapSecure      Boolean  @default(true)
  imapUser        String?
  imapPass        String?  // encrypted AES-256-GCM, same as smtpPass

  // Warmup pool settings (separate from cold email warmup)
  warmupPoolEnabled    Boolean @default(false)
  warmupPoolDay        Int     @default(0)
  warmupDailyTarget    Int     @default(2)
  warmupSentToday      Int     @default(0)
  warmupSentTodayDate  String  @default("")
  warmupReplyRate      Int     @default(30)
  warmupOpenRate       Int     @default(100)
  warmupSpamRescueRate Int     @default(100)
  warmupImportantRate  Int     @default(50)

  // IMAP health
  imapStatus        String    @default("unknown")
  imapLastError     String?
  imapLastCheckedAt DateTime?

  status            String   @default("active")
  lastErrorAt       DateTime?
  lastError         String?
  consecutiveErrors Int      @default(0)
  totalSent         Int      @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sends OutreachSend[]

  // Warmup pool relations
  warmupConversationsAsSender   WarmupConversation[] @relation("WarmupSender")
  warmupConversationsAsReceiver WarmupConversation[] @relation("WarmupReceiver")
  warmupEmailsSent              WarmupEmail[]        @relation("WarmupEmailSender")
  warmupEmailsReceived          WarmupEmail[]        @relation("WarmupEmailReceiver")
  warmupDailyStats              WarmupDailyStats[]

  @@index([isActive, status])
}

model OutreachContact {
  id               String    @id @default(cuid())
  email            String    @unique
  businessName     String
  firstName        String?
  category         String    @default("")
  city             String    @default("")
  cuisineType      String?
  website          String?
  phone            String?
  address          String?
  zipCode          String?
  source           String?
  customFields     String?

  status           String    @default("pending")
  unsubscribedAt   DateTime?
  unsubscribeToken String    @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sends           OutreachSend[]
  listMemberships OutreachListMember[]

  @@index([status])
  @@index([email])
  @@index([city, category])
  @@index([category])
}

model OutreachList {
  id           String   @id @default(cuid())
  name         String
  description  String?
  contactCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members   OutreachListMember[]
  campaigns OutreachCampaign[]

  @@index([name])
}

model OutreachListMember {
  id        String          @id @default(cuid())
  listId    String
  list      OutreachList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contactId String
  contact   OutreachContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt   DateTime        @default(now())

  @@unique([listId, contactId])
  @@index([listId])
  @@index([contactId])
}

model OutreachTemplate {
  id            String  @id @default(cuid())
  name          String
  subject       String
  htmlBody      String
  plainTextBody String
  description   String?
  variables     String  @default("[]")
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sends             OutreachSend[]
  campaignTemplates OutreachCampaignTemplate[]
}

model OutreachCampaign {
  id              String       @id @default(cuid())
  name            String
  listId          String
  list            OutreachList @relation(fields: [listId], references: [id])

  status          String  @default("draft")
  categoryFilter  String?
  delayMinutes    Int     @default(4)
  jitterSeconds   Int     @default(30)
  skipWeekends    Boolean @default(false)
  sendWindowStart Int     @default(9)
  sendWindowEnd   Int     @default(17)
  timezone        String  @default("America/New_York")
  allowResendDays Int     @default(0)

  totalContacts Int @default(0)
  sentCount     Int @default(0)
  failedCount   Int @default(0)

  startedAt   DateTime?
  pausedAt    DateTime?
  completedAt DateTime?
  lastSendAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates OutreachCampaignTemplate[]
  sends     OutreachSend[]

  @@index([status])
  @@index([listId])
}

model OutreachCampaignTemplate {
  id         String           @id @default(cuid())
  campaignId String
  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  templateId String
  template   OutreachTemplate @relation(fields: [templateId], references: [id])
  weight     Int              @default(1)

  @@unique([campaignId, templateId])
  @@index([campaignId])
}

model OutreachSend {
  id              String           @id @default(cuid())
  campaignId      String
  campaign        OutreachCampaign @relation(fields: [campaignId], references: [id])
  contactId       String
  contact         OutreachContact  @relation(fields: [contactId], references: [id])
  templateId      String
  template        OutreachTemplate @relation(fields: [templateId], references: [id])
  accountId       String
  account         EmailAccount     @relation(fields: [accountId], references: [id])

  renderedSubject String
  renderedHtml    String?
  renderedText    String?

  status       String   @default("pending")
  errorMessage String?
  sentAt       DateTime?
  messageId    String?

  createdAt DateTime @default(now())

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([accountId, sentAt])
  @@index([sentAt])
  @@index([status, contactId])
  @@index([status, sentAt])
  @@index([createdAt])
}

// ─── Warmup Pool System ─────────────────────────────────────────────────────

model WarmupConversation {
  id                String       @id @default(cuid())
  senderAccountId   String
  senderAccount     EmailAccount @relation("WarmupSender", fields: [senderAccountId], references: [id])
  receiverAccountId String
  receiverAccount   EmailAccount @relation("WarmupReceiver", fields: [receiverAccountId], references: [id])

  threadId  String @unique @default(cuid())
  subject   String
  topicKey  String
  turnCount Int    @default(0)
  maxTurns  Int    @default(3)
  status    String @default("active") // "active" | "completed" | "stale"

  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  emails WarmupEmail[]

  @@index([senderAccountId, status])
  @@index([receiverAccountId, status])
  @@index([status, lastMessageAt])
}

model WarmupEmail {
  id                String             @id @default(cuid())
  conversationId    String
  conversation      WarmupConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderAccountId   String
  senderAccount     EmailAccount       @relation("WarmupEmailSender", fields: [senderAccountId], references: [id])
  receiverAccountId String
  receiverAccount   EmailAccount       @relation("WarmupEmailReceiver", fields: [receiverAccountId], references: [id])

  warmupId  String @unique @default(cuid())
  messageId String?
  inReplyTo String?
  subject   String
  bodyText  String
  turnNumber Int

  // Action tracking
  opened           Boolean   @default(false)
  openedAt         DateTime?
  replied          Boolean   @default(false)
  repliedAt        DateTime?
  spamRescued      Boolean   @default(false)
  spamRescuedAt    DateTime?
  markedImportant  Boolean   @default(false)
  markedImportantAt DateTime?

  status       String    @default("sent")
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([conversationId, turnNumber])
  @@index([receiverAccountId, status])
  @@index([senderAccountId, sentAt])
  @@index([warmupId])
  @@index([createdAt])
}

model WarmupDailyStats {
  id              String       @id @default(cuid())
  accountId       String
  account         EmailAccount @relation(fields: [accountId], references: [id])
  date            String

  emailsSent      Int @default(0)
  emailsReceived  Int @default(0)
  opens           Int @default(0)
  replies         Int @default(0)
  spamRescues     Int @default(0)
  markedImportant Int @default(0)
  imapErrors      Int @default(0)

  createdAt DateTime @default(now())

  @@unique([accountId, date])
  @@index([accountId, date])
  @@index([date])
}
