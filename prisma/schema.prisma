generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Signup {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  businessName String?
  website      String?
  notes        String?
  createdAt    DateTime @default(now())
}
