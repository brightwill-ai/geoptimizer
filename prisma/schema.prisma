generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Signup {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  businessName String?
  website      String?
  notes        String?
  createdAt    DateTime @default(now())
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

model Analysis {
  id                        String            @id @default(cuid())
  userId                    String?
  user                      User?             @relation(fields: [userId], references: [id])
  businessName              String
  location                  String
  category                  String            @default("restaurant")
  tier                      String            @default("fast")
  status                    String            @default("pending")
  resultJson                String?
  errorMessage              String?
  queryCount                Int               @default(0)
  recommendationProbability Float?
  methodology               String?
  shareToken                String?           @unique
  startedAt                 DateTime          @default(now())
  completedAt               DateTime?
  expiresAt                 DateTime
  createdAt                 DateTime          @default(now())
  actionPlanJson            String?
  actionPlanStatus          String            @default("pending")
  paid                      Boolean           @default(false)
  stripeSessionId           String?
  paidAt                    DateTime?
  llmJobs                   LLMJob[]
  queryExecutions           QueryExecution[]
  sourceInfluences          SourceInfluence[]
  actionPlanItems           ActionPlanItem[]

  @@index([businessName, location, tier])
  @@index([status])
  @@index([userId])
}

model LLMJob {
  id           String    @id @default(cuid())
  analysisId   String
  analysis     Analysis  @relation(fields: [analysisId], references: [id])
  provider     String
  status       String    @default("pending")
  promptsSent  Int       @default(0)
  rawResponse  String?
  parsedJson   String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([analysisId, provider])
}

model QueryTemplate {
  id         String           @id @default(cuid())
  category   String
  queryType  String
  template   String
  tier       String           @default("free")
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  executions QueryExecution[]

  @@index([category, tier, isActive])
}

model QueryExecution {
  id                String         @id @default(cuid())
  analysisId        String
  analysis          Analysis       @relation(fields: [analysisId], references: [id])
  queryTemplateId   String?
  queryTemplate     QueryTemplate? @relation(fields: [queryTemplateId], references: [id])
  provider          String
  promptSent        String
  rawResponse       String         @default("")
  parsedJson        String?
  modelVersion      String         @default("")
  responseTimeMs    Int?
  businessMentioned Boolean        @default(false)
  mentionType       String?
  rankPosition      Int?
  sentiment         String?
  status            String         @default("pending")
  errorMessage      String?
  createdAt         DateTime       @default(now())

  @@index([analysisId, provider])
  @@index([provider, createdAt])
  @@index([queryTemplateId])
}

model SourceInfluence {
  id            String   @id @default(cuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id])
  sourceType    String
  sourceName    String
  provider      String
  citationCount Int      @default(0)
  influence     String   @default("unknown")
  createdAt     DateTime @default(now())

  @@index([analysisId])
  @@index([sourceType, provider])
}

model ActionPlanItem {
  id            String    @id @default(cuid())
  analysisId    String
  analysis      Analysis  @relation(fields: [analysisId], references: [id])
  categoryKey   String
  categoryLabel String
  itemIndex     Int
  priority      String
  title         String
  description   String
  reasoning     String
  effort        String
  dataPoints    String?
  completed     Boolean   @default(false)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([analysisId, categoryKey])
  @@index([analysisId, completed])
}
