# Database (SQLite file for local dev)
DATABASE_URL="file:./prisma/dev.db"

# LLM API Keys (required for /analyze backend)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AI..."

# Optional: LiteLLM proxy URL (e.g. Duke AI Gateway for dev)
# When set, OpenAI SDK routes through this proxy instead of api.openai.com
# OPENAI_BASE_URL="https://litellm.oit.duke.edu/v1"
