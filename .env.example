# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# LLM API Keys (required for /analyze backend)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AI..."

# Optional: LiteLLM proxy URL (e.g. Duke AI Gateway for dev)
# When set, OpenAI SDK routes through this proxy instead of api.openai.com
# OPENAI_BASE_URL="https://litellm.oit.duke.edu/v1"

# Email (Resend — for sending comprehensive report links + payment confirmations)
RESEND_API_KEY="re_..."
APP_URL="https://brightwill.ai/"
# RESEND_FROM_EMAIL="BrightWill <reports@brightwill.ai>"

# Stripe (payment gate — $19 Full Audit + $199 Audit + Strategy)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."
STRIPE_PRICE_ID_STRATEGY="price_..."

# Admin dashboard (/admin)
ADMIN_PASSWORD="your-secure-password"

# Outreach system (admin dashboard → Outreach tab)
# 32-byte hex key for AES-256-GCM encryption of SMTP passwords in DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OUTREACH_ENCRYPTION_KEY="your-64-char-hex-string"
# Secret for cron job authentication (POST /api/admin/outreach/send)
CRON_SECRET="your-cron-secret"
